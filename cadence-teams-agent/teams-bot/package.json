{
  "name": "cadence-teams-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Cadence agent for Microsoft Teams — plans and operates enterprise work via the shared Cadence API and Azure AI Foundry",
  "main": "dist/index.js",
  "scripts": {
