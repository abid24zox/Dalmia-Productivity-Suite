  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/restify": "^8.5.12",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  }
}
