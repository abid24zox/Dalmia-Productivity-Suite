# ---- Cadence service ----
PORT=4000
# Optional shared secret. If set, bot must send x-api-key; login/health/AI stay open.
CADENCE_API_KEY=

# ---- Azure AI Foundry (same deployment the Teams bot uses) ----
# The portal's in-house AI calls these through the service, so no model key
# ever reaches the browser.
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ---- Deepgram speech-to-text (add later; portal falls back to browser STT until set) ----
DEEPGRAM_API_KEY=
