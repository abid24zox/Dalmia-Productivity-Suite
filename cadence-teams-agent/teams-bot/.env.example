# ---- Azure Bot Service registration (you already have this) ----
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TYPE=MultiTenant
MICROSOFT_APP_TENANT_ID=

# ---- Azure AI Foundry model (Azure OpenAI-compatible chat + tool calling) ----
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---- Shared Cadence service ----
CADENCE_API_URL=http://localhost:4000
CADENCE_API_KEY=

# ---- Portal deep link shown on cards ----
PORTAL_URL=https://cadence.contoso.com

# ---- Demo fallback identity if the Teams user isn't linked to a Cadence user ----
DEFAULT_CADENCE_USER_ID=u_vik

# ---- Bot host port ----
PORT=3978
